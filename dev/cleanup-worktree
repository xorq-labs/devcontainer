#!/usr/bin/env bash
set -euo pipefail

if [[ "${1:-}" =~ ^(-h|--help)$ ]]; then
    cat <<'USAGE'
Usage: cleanup-worktree [path]

Remove a git worktree and undo overlay symlinks/copies created by
setup-worktree. Defaults to the current directory if no path is given.
USAGE
    exit 0
fi

_base="$(cd "$(dirname "$(readlink -f "$0")")/.." && pwd)"
. "$_base/lib/git.sh"
if [ -n "${1:-}" ]; then
    here="$(cd "$1" && git rev-parse --show-toplevel)"
else
    here=$(git rev-parse --show-toplevel)
fi
main=$(dev_main_tree)
manifest="$here/.envrcs/.worktree-manifest"

# Pre-flight: verify git worktree remove will succeed before we touch anything.
# Collect untracked+modified files, subtract manifest entries (which we clean up
# ourselves), and fail early if anything else would block removal.
_dirty=$(git -C "$here" status --porcelain 2>/dev/null | awk '{print $NF}') || true
if [ -n "$_dirty" ] && [ -f "$manifest" ]; then
    _dominated=()
    while IFS=$'\t' read -r _act _ent; do
        [ -z "$_ent" ] && _ent="$_act"
        _dominated+=("$_ent")
    done < "$manifest"
    _dominated+=(".envrcs/.worktree-manifest")
    _remaining=""
    for _f in $_dirty; do
        _dominated_match=false
        for _d in "${_dominated[@]}"; do
            if [ "$_f" = "$_d" ]; then _dominated_match=true; break; fi
        done
        $_dominated_match || _remaining="$_remaining $_f"
    done
    if [ -n "$_remaining" ]; then
        echo "error: worktree has untracked/modified files that would block removal:" >&2
        for _f in $_remaining; do echo "  $_f" >&2; done
        echo "clean these up first, or use: git worktree remove --force $here" >&2
        exit 1
    fi
elif [ -n "$_dirty" ]; then
    echo "error: worktree has untracked/modified files that would block removal:" >&2
    echo "$_dirty" | sed 's/^/  /' >&2
    echo "clean these up first, or use: git worktree remove --force $here" >&2
    exit 1
fi

if [ -f "$manifest" ]; then
    cd "$here"
    while IFS=$'\t' read -r action entry; do
        [ -z "$entry" ] && {
            # Legacy manifest (bare path, no action column)
            entry="$action"
            action=""
        }
        case "$action" in
            symlink)
                if [ -L "$entry" ]; then
                    rm -v "$entry"
                elif [ -e "$entry" ]; then
                    echo "skipping $entry (manifest says symlink, but it is not one)" >&2
                fi
                ;;
            copy)
                if [ -L "$entry" ]; then
                    _target="$(readlink -f "$entry" 2>/dev/null || true)"
                    if [ -z "$_target" ] || [[ "$_target" != "$main/"* ]]; then
                        # Symlink to an external path (cp -P preserved it) or
                        # dangling — safe to remove.
                        rm -v "$entry"
                    else
                        echo "skipping $entry (manifest says copy, found symlink into main tree)" >&2
                    fi
                elif [ -f "$entry" ]; then
                    if git ls-files --error-unmatch "$entry" &>/dev/null; then
                        git checkout -- "$entry"
                    else
                        rm -v "$entry" || true
                    fi
                elif [ -d "$entry" ]; then
                    echo "skipping $entry (manifest says copy, found directory)" >&2
                fi
                ;;
            *)
                # Legacy format: best-effort removal (old behavior)
                if [ -L "$entry" ]; then
                    rm -v "$entry"
                elif [ -f "$entry" ]; then
                    rm -v "$entry" || true
                elif [ -d "$entry" ]; then
                    echo "skipping $entry (expected symlink, found directory)" >&2
                fi
                ;;
        esac
    done < "$manifest"
    # Remove any empty parent directories created by setup
    while IFS=$'\t' read -r action entry; do
        # Legacy manifest: bare path with no tab lands entirely in $action
        [ -z "$entry" ] && entry="$action"
        dir=$(dirname "$entry")
        rmdir -p "$dir" 2>/dev/null || true
    done < "$manifest"
    rm -v "$manifest"
fi

cd "$main"
git worktree unlock "$here" 2>/dev/null || true
git worktree remove "$here" || {
    git worktree lock "$here" \
        --reason "re-locked after failed remove" 2>/dev/null || true
    exit 1
}
