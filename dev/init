#!/usr/bin/env bash
set -euo pipefail

# Create a project overlay for devcontainer.
#
# Usage (shipped overlay in devcontainer repo):
#   devcontainer init [project-name]
#
# Usage (local overlay in workspace, gitignored):
#   devcontainer init --local [project-name]
#
# Add --nix to any of the above to layer a Nix store (build-time install,
# runtime-volume-backed) onto the overlay.

base="$(cd "$(dirname "$(readlink -f "$0")")/.." && pwd)"
. "$base/lib/git.sh"

local_mode=false
nix_mode=false
project_name=""
for arg in "$@"; do
    case "$arg" in
        --local) local_mode=true ;;
        --nix) nix_mode=true ;;
        -*) echo "error: unknown flag: $arg" >&2; exit 1 ;;
        *) project_name="$arg" ;;
    esac
done

if [ -z "$project_name" ]; then
    main_tree="$(dev_main_tree)" || {
        echo "error: not in a git repo and no project name given" >&2
        echo "usage: devcontainer init [--local] [--nix] [project-name]" >&2
        exit 1
    }
    project_name="$(basename "$main_tree")"
else
    main_tree="$(dev_main_tree 2>/dev/null)" || true
fi

if $local_mode; then
    if [ -z "${main_tree:-}" ]; then
        echo "error: --local requires being inside a git repo" >&2
        exit 1
    fi
    target="$main_tree/.devcontainer"
    # Seed from shipped defaults if they exist, otherwise generic defaults.
    if [ -d "$base/projects/$project_name" ]; then
        source_dir="$base/projects/$project_name"
    else
        source_dir="$base/defaults"
    fi
    label=".devcontainer/ (local)"
else
    target="$base/projects/$project_name"
    source_dir="$base/defaults"
    label="projects/$project_name/"
fi

mkdir -p "$target"

echo "Creating project overlay: $label"

copied=0
for f in install-system.sh setup-env.sh compose.override.yml devcontainer.json \
         external-volumes.txt worktree-symlinks.txt worktree-copies.txt \
         audit-prefixes.txt host-mounts.txt project.env.example; do
    if [ ! -f "$target/$f" ]; then
        cp "$source_dir/$f" "$target/$f"
        echo "  created $f"
        copied=$((copied + 1))
    else
        echo "  exists  $f (skipped)"
    fi
done

echo ""
echo "Created $copied file(s) in $target/"

# --nix layers the nix fragment (install-system.sh, setup-env.sh,
# compose.override.yml, external-volumes.txt) over the defaults copy above,
# overwriting only the files nix touches. The invariant tail (host-mounts,
# worktree provisioning, audit, devcontainer.json, project.env) stays from
# defaults. The seed logic itself lives in lib/nix-seed.sh, which the
# generated scripts source — no per-overlay copy of it.
if $nix_mode; then
    nix_frag="$base/templates/nix"
    echo ""
    echo "Applying --nix fragment:"
    # These four are always applied (that's the point of --nix), so an existing
    # target is overwritten rather than skipped like the base loop — say so
    # honestly instead of reporting every file as freshly written.
    for f in install-system.sh setup-env.sh compose.override.yml external-volumes.txt; do
        if [ -f "$target/$f" ]; then
            cp "$nix_frag/$f" "$target/$f"
            echo "  nix     $f (overwrote)"
        else
            cp "$nix_frag/$f" "$target/$f"
            echo "  nix     $f"
        fi
    done
    echo ""
    echo "Nix is a project-scoped shared volume (\${DEV_PROJECT_NAME}-nix), reused by"
    echo "every worktree; remove it later with 'devcontainer clean-caches'."
fi

if $local_mode; then
    echo ""
    echo "This directory is picked up as a tier-2 override (workspace-local)."
    echo "Add .devcontainer/ to .gitignore if you don't want to track it."
    echo ""
    echo "Next steps:"
    echo "  1. Edit .devcontainer/install-system.sh   — system packages"
    echo "  2. Edit .devcontainer/setup-env.sh         — dependency install / sync"
    echo "  3. Edit .devcontainer/compose.override.yml — volumes, env vars"
    echo "  4. Edit .devcontainer/devcontainer.json    — container name, IDE settings"
    echo "  5. Run: devcontainer up"
else
    echo ""
    echo "Next steps:"
    echo "  1. Edit projects/$project_name/install-system.sh   — system packages"
    echo "  2. Edit projects/$project_name/setup-env.sh         — dependency install / sync"
    echo "  3. Edit projects/$project_name/compose.override.yml — volumes, env vars"
    echo "  4. Edit projects/$project_name/devcontainer.json    — container name, IDE settings"
    echo "  5. cd to the workspace and run: devcontainer up"
fi
