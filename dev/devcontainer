#!/usr/bin/env bash
set -euo pipefail

# Naming convention: DEV_* identifies dev-container infrastructure values
# (paths, IDs, flags) — used as the canonical name for both script-locals
# and exported env vars, Dockerfile build args, and compose interpolations.
# User-facing config in project.env keeps unprefixed names (MODEL_VERSION,
# DANGEROUSLY_SKIP_PERMISSIONS); they are translated to DEV_* on entry.

if [ "${1:-}" = "completions" ]; then
    shift
    exec "$(dirname "$(readlink -f "$0")")/devcontainer-completions" "$@"
fi

# Pure host-side helper: install completions to each shell's autoload dir.
# Dispatch before the git/compose/project resolution below (which it doesn't need).
if [ "${1:-}" = "install-completions" ]; then
    shift
    exec "$(dirname "$(readlink -f "$0")")/install-completions" "$@"
fi

# Pure host-side maintenance: bumping the pinned Claude Code version only
# touches the Dockerfile, so dispatch before the git/compose/project
# resolution below (which would need a running repo/overlay context).
if [ "${1:-}" = "bump-claude-code" ]; then
    shift
    exec "$(dirname "$(readlink -f "$0")")/bump-claude-code" "$@"
fi

show_usage() {
    cat <<'USAGE'
Usage: devcontainer [-w dir] <command>

Commands:
  init [name]                         create a project overlay (default: workspace basename)
  up                                  start the dev container (default)
  down [--yes]                        stop the dev container
  reset [--yes]                       destroy container and all volumes
  clean [--yes]                       reset + remove images and host-side artifacts
  clean-caches [--yes]                remove the project's shared caches (external volumes:
                                        nix store, package caches) — affects ALL worktrees
  status                              show whether the container is running
  list                                list all worktrees with container status and overlay
  resolve                             show resolved overlay and configuration (dry run)
  logs [args...]                      show container logs
  exec [cmd...]                       run a command (default: bash)
  claude [args...]                    run claude
  claude-dangerously-skip-permissions run claude with --dangerously-skip-permissions
  refresh-ssh                         re-forward SSH agent (runs automatically on up/exec/claude;
                                        use standalone when agent changes mid-session)
  refresh-gpg                         re-forward GPG agent (runs automatically on up/exec/claude;
                                        use standalone when host gpg-agent restarts)
  copy-host-transcripts               mirror host Claude session transcripts into the
                                        container so `claude --resume` finds them (runs
                                        automatically on up/exec/claude; use standalone to
                                        pull a host session started after the container was up)
  fix-credentials                     repair credentials symlink in a running container
                                        (needed after upgrading from pre-shared-credentials build)
  fix-network                         disconnect stale networks from a stopped container
                                        (needed after ungraceful host shutdown)
  unlock                              remove stale lockfile (safe — refuses if lock is actively held)
  ps [--all]                          list running containers for this project (--all: all containers with claude sessions)
  audit [--summary|--new|--all|--clear]
                                      show permission audit log (default: --summary)
  bump-claude-code [version|--check]  update pinned Claude Code version in the Dockerfile
                                        (default: latest from npm; --check reports without editing)
  completions [bash|zsh|fish]         emit shell completions
  install-completions [bash|zsh|fish] install completions to each shell's autoload dir
                                        (default: every shell present; --print-paths to preview)
USAGE
}

if [[ "${1:-}" =~ ^(-h|--help|help)$ ]]; then
    show_usage
    exit 0
fi

if [ "$(uname -s)" != "Linux" ]; then
    echo "error: devcontainer requires Linux (uses GNU coreutils)" >&2
    exit 1
fi

while [[ "${1:-}" == -* ]]; do
    case "$1" in
        -w|--workspace)
            shift
            if [ $# -eq 0 ]; then
                echo "error: --workspace requires an argument" >&2
                exit 1
            fi
            DEV_WORKSPACE="$1"; shift ;;
        *) echo "Unknown option: $1" >&2; exit 1 ;;
    esac
done

# Resolve through symlinks and PATH to find the base repo
_SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "$0")")" && pwd)"
DEV_BASE_DIR="$(cd "$_SCRIPT_DIR/.." && pwd)"
export DEV_BASE_DIR

. "$DEV_BASE_DIR/lib/git.sh"
DEV_MAIN_TREE="$(dev_main_tree)" || exit 1
export DEV_MAIN_TREE

# Project overlay resolution: DEV_PROJECT_DIR env var (explicit) takes
# precedence, otherwise resolve_project_dir walks the standard tiers.
DEV_PROJECT_NAME="${DEV_PROJECT_NAME:-$(basename "$DEV_MAIN_TREE")}"
if [ -z "${DEV_PROJECT_DIR:-}" ]; then
    DEV_PROJECT_DIR="$(resolve_project_dir "$DEV_BASE_DIR" "$DEV_MAIN_TREE" "$DEV_PROJECT_NAME")"
fi
export DEV_PROJECT_DIR

COMPOSE_FILE="$DEV_BASE_DIR/docker-compose.yml"
COMPOSE_OVERRIDE="$DEV_PROJECT_DIR/compose.override.yml"

# not configurable — compose, Dockerfile, and setup-claude all assume this path
DEV_CONTAINER_WORKSPACE="/workspaces/src"

DEV_WORKSPACE="${DEV_WORKSPACE:-.}"

if [[ "${1:-up}" =~ ^(down|reset|clean|clean-caches|status|logs|list|resolve)$ ]]; then
    if [ -d "$DEV_WORKSPACE" ]; then
        export DEV_WORKSPACE="$(cd "$DEV_WORKSPACE" && pwd)"
    else
        export DEV_WORKSPACE="$(readlink -m "$DEV_WORKSPACE")"
    fi
else
    if [ ! -d "$DEV_WORKSPACE" ]; then
        echo "error: workspace directory does not exist: $DEV_WORKSPACE" >&2
        exit 1
    fi
    export DEV_WORKSPACE="$(cd "$DEV_WORKSPACE" && pwd)"
fi

# Auto-resolve to git root when workspace is a subdirectory of a checkout.
# Mounting a subdirectory as the container workspace leaves /workspaces/src
# without a .git entry, so git (and tools like Claude Code) can't find the
# repo and fail with "not a git repository".
if [ -d "$DEV_WORKSPACE" ]; then
    _git_toplevel="$(git -C "$DEV_WORKSPACE" rev-parse --show-toplevel 2>/dev/null)" || {
        echo "error: $DEV_WORKSPACE is not inside a git repository" >&2
        exit 1
    }
    if [ "$DEV_WORKSPACE" != "$_git_toplevel" ]; then
        echo "note: resolving workspace to git root: $_git_toplevel (was: $DEV_WORKSPACE)" >&2
        export DEV_WORKSPACE="$_git_toplevel"
    fi
fi

# MODEL_VERSION and DANGEROUSLY_SKIP_PERMISSIONS from the project overlay's project.env.
_project_env="$DEV_PROJECT_DIR/project.env"
# shellcheck disable=SC1090
[ -f "$_project_env" ] && . "$_project_env"
[ -n "${MODEL_VERSION:-}" ] && export DEV_MODEL_VERSION="$MODEL_VERSION"
unset MODEL_VERSION
[ -n "${DANGEROUSLY_SKIP_PERMISSIONS:-}" ] && DEV_DANGEROUSLY_SKIP_PERMISSIONS=1
unset DANGEROUSLY_SKIP_PERMISSIONS
export DEV_UID="$(id -u)"
export DEV_GID="$(id -g)"
export DEV_MAIN_GIT="$DEV_MAIN_TREE/.git"
export DEV_HOST_USER="$(whoami)"
export DEV_PROJECT_NAME
export DEV_CONTAINER_WORKSPACE

_overlay_label="$(project_dir_label "$DEV_PROJECT_DIR" "$DEV_BASE_DIR")"

# SSH and GPG agent forwarding: socat bridges the host agents into the
# container over TCP via host.docker.internal, so the container never
# bind-mounts the sockets directly.  `devcontainer refresh-ssh` and
# `devcontainer refresh-gpg` restart the respective bridges without
# rebuilding or restarting the container.  For tighter SSH control,
# use `ssh-add -c` (confirm each use) or load only the keys you need.

if [ -d "${HOME}/.config/sops/age" ]; then
    export DEV_SOPS_AGE_DIR="${HOME}/.config/sops/age"
else
    # mount an empty directory so the container sees a keyless dir, not a device file
    DEV_SOPS_AGE_DIR="/tmp/devcontainer-empty-sops-age"
    mkdir -p "$DEV_SOPS_AGE_DIR"
    export DEV_SOPS_AGE_DIR
    echo "warning: no sops age key found — sops-encrypted envrc secrets won't decrypt inside the container" >&2
fi

# Nix overlays mount the host's nix config read-only; fall back to an empty dir
# so a missing ~/.config/nix doesn't make Docker auto-create a root-owned dir on
# the host. A missing host config is normal — nix_write_conf writes safe
# defaults — so no warning here.
if [ -d "${HOME}/.config/nix" ]; then
    export DEV_NIX_HOST_CONF="${HOME}/.config/nix"
else
    DEV_NIX_HOST_CONF="/tmp/devcontainer-empty-nix-conf"
    mkdir -p "$DEV_NIX_HOST_CONF"
    export DEV_NIX_HOST_CONF
fi

if [ "$DEV_WORKSPACE" = "$DEV_MAIN_TREE" ]; then
    export DEV_WORKTREE="main"
else
    export DEV_WORKTREE="$(basename "$DEV_WORKSPACE")"
fi

# sanitize for docker compose: project names allow only [a-z0-9_-]
DEV_CONTAINER_NAME="$(echo "${DEV_PROJECT_NAME}-dev-$(basename "$DEV_WORKSPACE")" | tr -cs 'a-zA-Z0-9_-' '-' | sed 's/-$//' | tr '[:upper:]' '[:lower:]')"
DEV_LOCKFILE="/tmp/devcontainer-${DEV_CONTAINER_NAME}.lock"

write_resolved_env() {
    local dest="$1"
    mkdir -p "$(dirname "$dest")"
    {
        echo '# Auto-generated by dev/devcontainer — do not edit.'
        echo '# Resolved overlay and project.env values for this worktree.'
        printf 'OVERLAY=%q\n' "$_overlay_label"
        printf 'OVERLAY_DIR=%q\n' "$DEV_PROJECT_DIR"
        printf 'PROJECT_NAME=%q\n' "$DEV_PROJECT_NAME"
        printf 'MODEL_VERSION=%q\n' "${DEV_MODEL_VERSION:-}"
        printf 'DANGEROUSLY_SKIP_PERMISSIONS=%q\n' "${DEV_DANGEROUSLY_SKIP_PERMISSIONS:-}"
        printf 'CONTAINER_NAME=%q\n' "$DEV_CONTAINER_NAME"
    } > "$dest"
}

# shellcheck disable=SC2034  # consumed by lib/host-bridge.sh
DEV_HAS_SOCAT=false
if command -v socat >/dev/null 2>&1; then
    # shellcheck disable=SC2034
    DEV_HAS_SOCAT=true
fi

dc() {
    local files=(-f "$COMPOSE_FILE")
    [ -f "$COMPOSE_OVERRIDE" ] && files+=(-f "$COMPOSE_OVERRIDE")
    [ -n "${DEV_HOST_MOUNTS_OVERRIDE:-}" ] && files+=(-f "$DEV_HOST_MOUNTS_OVERRIDE")
    docker compose "${files[@]}" -p "$DEV_CONTAINER_NAME" "$@"
}

dc_exec() {
    dc exec \
        -e DEV_WORKTREE="$DEV_WORKTREE" \
        app "$@"
}

is_running() {
    dc ps --status running --format '{{.Service}}' 2>/dev/null | grep -q '^app$'
}

config_files() {
    local df="$DEV_BASE_DIR/Dockerfile"
    [ -f "$df" ] || { echo "error: $df not found" >&2; return 1; }
    printf '%s\n' \
        "$df" \
        "$COMPOSE_FILE" \
        "$DEV_BASE_DIR/setup-claude.py" \
        "$DEV_BASE_DIR/audit-hook" \
        "$DEV_PROJECT_DIR/install-system.sh" \
        "$DEV_PROJECT_DIR/setup-env.sh"
    [ -f "$COMPOSE_OVERRIDE" ] && printf '%s\n' "$COMPOSE_OVERRIDE"
    local hm
    for hm in \
        "$DEV_PROJECT_DIR/host-mounts.txt" \
        "$DEV_PROJECT_DIR/host-mounts.local.txt"; do
        [ -f "$hm" ] && printf '%s\n' "$hm"
    done
    :
}

config_hash() {
    local files
    files="$(config_files)" || return 1
    {
        while IFS= read -r f; do
            cat "$f"
        done <<< "$files"
        # Build args interpolated into compose at build time are baked into
        # the image and don't show up in file-content hashing — include them
        # explicitly so a change forces rebuild. Anything else baked via env
        # interpolation must be added here.
        printf 'DEV_CONTAINER_WORKSPACE=%s\n' "$DEV_CONTAINER_WORKSPACE"
        printf 'DEV_PROJECT_DIR=%s\n' "$DEV_PROJECT_DIR"
    } | sha256sum | cut -d' ' -f1
}

config_file_desc() {
    case "$(basename "$1")" in
        Dockerfile)            echo "base image, system packages" ;;
        docker-compose.yml)    echo "volumes, ports, orchestration" ;;
        compose.override.yml)  echo "project compose overrides" ;;
        setup-claude.py)       echo "Claude Code permissions and settings" ;;
        audit-hook)            echo "security audit hook" ;;
        install-system.sh)     echo "system package installation" ;;
        setup-env.sh)          echo "environment setup" ;;
        host-mounts.txt)       echo "host directory mounts" ;;
        host-mounts.local.txt) echo "local host mount overrides" ;;
        *)                     echo "" ;;
    esac
}

save_config_hashes() {
    config_files | while IFS= read -r f; do
        [ -f "$f" ] && sha256sum "$f"
    done > "/tmp/devcontainer-${DEV_CONTAINER_NAME}.file-hashes"
}

show_config_changes() {
    local saved="/tmp/devcontainer-${DEV_CONTAINER_NAME}.file-hashes"
    if [ ! -f "$saved" ]; then
        echo "  (no baseline — cannot determine which files changed)"
        return
    fi
    local files current_hash saved_hash desc
    files="$(config_files)" || return 1
    while IFS= read -r f; do
        [ -f "$f" ] || continue
        current_hash="$(sha256sum "$f" | cut -d' ' -f1)"
        saved_hash="$(grep -F "  $f" "$saved" | head -1 | cut -d' ' -f1)" || true
        desc="$(config_file_desc "$f")"
        [ -n "$desc" ] && desc=" ($desc)"
        if [ -z "$saved_hash" ]; then
            printf '  + %s%s\n' "$(basename "$f")" "$desc"
        elif [ "$current_hash" != "$saved_hash" ]; then
            printf '  ~ %s%s\n' "$(basename "$f")" "$desc"
        fi
    done <<< "$files"
}

image_stale() {
    local container_id
    container_id="$(dc ps -q app 2>/dev/null | head -1)" || return 0
    [ -z "$container_id" ] && return 0

    local container_image tagged_image
    container_image="$(docker inspect --format '{{.Image}}' "$container_id")" || return 0
    tagged_image="$(docker image inspect --format '{{.ID}}' "${DEV_CONTAINER_NAME}:$(config_hash)" 2>/dev/null)" || return 0

    [ "$container_image" != "$tagged_image" ]
}

tag_image() {
    docker tag "$(dc images -q app)" "${DEV_CONTAINER_NAME}:$(config_hash)" \
        || echo "warning: could not tag image — staleness check will re-trigger next run" >&2
    save_config_hashes
}

require_tty() {
    if [ ! -t 0 ]; then
        echo "error: '$1' requires an interactive terminal (TTY)" >&2
        exit 1
    fi
}

# Generic host<->container bridge: SSH agent forwarding, host git/gh/Claude
# config copy. Defined separately so this script stays focused on orchestration.
. "$DEV_BASE_DIR/lib/host-bridge.sh"
. "$DEV_BASE_DIR/lib/list-file.sh"
. "$DEV_BASE_DIR/lib/host-mounts.sh"

generate_host_mounts_override

# Named-volume mount targets from the merged compose config — these come
# up root-owned and need chowning before user-mode setup runs. Deriving
# from compose means projects only declare volumes in compose.override.yml.
named_volume_targets() {
    local cfg
    cfg="$(dc config --format=json)" || {
        echo "error: 'docker compose config' failed — cannot derive named-volume mount targets" >&2
        return 1
    }
    printf '%s' "$cfg" | python3 -c '
import json, sys
cfg = json.load(sys.stdin)
for v in cfg.get("services", {}).get("app", {}).get("volumes") or []:
    if v.get("type") == "volume" and v.get("target"):
        print(v["target"])
'
}

# First-run setup: chown root-owned named-volume mount points, set up the
# host-path symlink for tools that persist absolute paths, then delegate
# to the project's setup-env first-run.
setup() {
    named_volume_targets | dc exec -T -u root app sh -c '
        while IFS= read -r d; do
            [ -n "$d" ] || continue
            chown -R vscode:vscode "$d" 2>/dev/null || true
            p="$(dirname "$d")"
            while [ "$p" != "/" ] && [ "$p" != "." ]; do
                case "$p" in
                    /home/vscode/*) ;;
                    *) break ;;
                esac
                chown vscode:vscode "$p" 2>/dev/null || true
                p="$(dirname "$p")"
            done
        done
    '

    if [ "$DEV_WORKSPACE" != "$DEV_CONTAINER_WORKSPACE" ] \
        && [ "$DEV_WORKSPACE" != "$DEV_MAIN_TREE" ]; then
        dc exec -u root \
            -e DEV_WORKSPACE="$DEV_WORKSPACE" \
            -e DEV_CONTAINER_WORKSPACE="$DEV_CONTAINER_WORKSPACE" \
            app sh -c '
                mkdir -p "$(dirname "$DEV_WORKSPACE")"
                ln -sfn "$DEV_CONTAINER_WORKSPACE" "$DEV_WORKSPACE"
            '
    fi

    dc exec app setup-env first-run
    echo "Dev container ready: $DEV_CONTAINER_NAME"
}

# re-sync dependencies when lockfile changes — also project-defined
sync_if_needed() {
    dc_exec setup-env sync-if-needed
}

ensure_external_volumes() {
    while IFS= read -r name; do
        docker volume create "${DEV_PROJECT_NAME}-${name}" >/dev/null 2>&1 || true
    done < <(read_list "$DEV_PROJECT_DIR/external-volumes.txt")
}

# Disconnect networks whose stored ID no longer matches the live network.
# This happens when Docker recreates a network with the same name after an
# ungraceful shutdown — the container still references the old (deleted) ID.
disconnect_stale_networks() {
    local container_id="$1"
    local fixed=0
    local net stored_id live_id
    for net in $(docker inspect --format '{{range $name, $net := .NetworkSettings.Networks}}{{$name}}={{$net.NetworkID}} {{end}}' "$container_id"); do
        local name="${net%%=*}"
        stored_id="${net#*=}"
        live_id="$(docker network inspect --format '{{.Id}}' "$name" 2>/dev/null)" || live_id=""
        if [ -z "$live_id" ] || [ "$stored_id" != "$live_id" ]; then
            echo "Disconnecting stale network: $name" >&2
            docker network disconnect -f "$name" "$container_id"
            ((fixed++))
        fi
    done
    return "$fixed"
}

# Run `dc up --build -d`, streaming output while also capturing it to detect
# known failure patterns (e.g. Docker network exhaustion).
dc_up() {
    local _up_tmp _up_rc
    _up_tmp=$(mktemp)
    # shellcheck disable=SC2064
    trap "rm -f '$_up_tmp'" RETURN
    dc up --build -d 2>&1 | tee "$_up_tmp" && _up_rc=0 || _up_rc=$?
    if [ "$_up_rc" -ne 0 ]; then
        if grep -q "network.*not found" "$_up_tmp"; then
            echo "" >&2
            echo "Container references a deleted network (likely after ungraceful host shutdown)." >&2
            echo "Attempting automatic recovery..." >&2
            local container_id
            container_id="$(dc ps -aq app 2>/dev/null | head -1)" || true
            if [ -n "$container_id" ]; then
                disconnect_stale_networks "$container_id" || true
                dc up --build -d 2>&1 | tee "$_up_tmp" && _up_rc=0 || _up_rc=$?
            fi
        fi
        if [ "$_up_rc" -ne 0 ] && grep -q "could not find an available.*address pool" "$_up_tmp"; then
            echo "" >&2
            echo "Docker ran out of network address space." >&2
            echo "Run 'docker network prune' to remove unused networks, then retry." >&2
        fi
        return "$_up_rc"
    fi
}

ensure_up() {
    # Subshell scopes fd 9 so no child process can inherit the flock.
    (
        if ! flock -n 9; then
            echo "Another devcontainer operation is in progress, waiting..."
            while ! flock -n 9; do
                sleep 1
            done
        fi

        echo "overlay: $_overlay_label"
        write_resolved_env "$DEV_WORKSPACE/.envrcs/.resolved-env"
        setup_claude_credentials
        install_hooks
        ensure_external_volumes
        if [ "$DEV_WORKSPACE" != "$DEV_MAIN_TREE" ]; then
            (cd "$DEV_WORKSPACE" && "$DEV_BASE_DIR/dev/setup-worktree")
            printf 'copy\t%s\n' ".envrcs/.resolved-env" >> "$DEV_WORKSPACE/.envrcs/.worktree-manifest"
        fi

        if ! is_running; then
            dc_up
            tag_image
            setup
        elif image_stale; then
            echo "Devcontainer config has changed since the container was built:"
            show_config_changes
            echo ""
            echo "  r) Rebuild container to apply changes"
            echo "  c) Continue with existing container"
            echo "  q) Quit"
            read -rp "Choice [r/c/q]: " answer
            case "$answer" in
                [rR]*)
                    dc down
                    dc_up
                    tag_image
                    setup
                    ;;
                [qQ]*)
                    exit 2
                    ;;
                *)
                    echo "Continuing with existing container. Changes apply on next rebuild."
                    ;;
            esac
        fi

        setup_git
        setup_gh
        setup_ssh_forward 9>&-
        setup_gpg_forward 9>&-
        setup_x11_forward 9>&-
        setup_claude
        sync_if_needed
    ) 9>"$DEV_LOCKFILE"
}

case "${1:-up}" in
    init)
        shift
        exec "$DEV_BASE_DIR/dev/init" "$@"
        ;;
    up)
        ensure_up
        ;;
    down)
        if is_running && [[ "${2:-}" != "--yes" && "${2:-}" != "-y" ]]; then
            read -rp "Running container will be stopped. Continue? [y/N] " answer
            if [[ "$answer" != [yY]* ]]; then
                exit 0
            fi
        fi
        stop_ssh_forward
        stop_gpg_forward
        stop_x11_forward
        dc down
        ;;
    reset)
        if [[ "${2:-}" != "--yes" && "${2:-}" != "-y" ]]; then
            read -rp "This will destroy the container and its per-worktree volumes (venv, build target). Shared project caches (external volumes) are kept — use 'devcontainer clean-caches' to remove those. Continue? [y/N] " answer
            if [[ "$answer" != [yY]* ]]; then
                exit 0
            fi
        fi
        stop_ssh_forward
        stop_gpg_forward
        stop_x11_forward
        dc down --volumes
        ;;
    clean)
        if [[ "${2:-}" != "--yes" && "${2:-}" != "-y" ]]; then
            read -rp "This will destroy $DEV_CONTAINER_NAME (container, per-worktree volumes, images, audit log, and session captures). Shared project caches (external volumes) are kept — use 'devcontainer clean-caches' to remove those. Continue? [y/N] " answer
            if [[ "$answer" != [yY]* ]]; then
                exit 0
            fi
        fi
        stop_ssh_forward
        stop_gpg_forward
        stop_x11_forward
        dc down --volumes --rmi local
        docker images --format '{{.Repository}}:{{.Tag}}' \
            | grep "^${DEV_CONTAINER_NAME}:" \
            | xargs -r docker rmi 2>/dev/null || true
        rm -rf "$DEV_WORKSPACE/.claude/container-audit"
        rm -rf "$DEV_WORKSPACE/.claude/container-sessions"
        echo "Cleaned: $DEV_CONTAINER_NAME"
        ;;
    clean-caches)
        # Remove the project's shared external volumes (nix store, package
        # caches). These are scoped to DEV_PROJECT_NAME and shared by every
        # worktree, so `down --volumes`/reset/clean never touch them. This is a
        # project-wide operation, not per-worktree.
        _caches=()
        while IFS= read -r _name; do
            _caches+=("${DEV_PROJECT_NAME}-${_name}")
        done < <(read_list "$DEV_PROJECT_DIR/external-volumes.txt")

        if [ "${#_caches[@]}" -eq 0 ]; then
            echo "No shared caches declared for project '$DEV_PROJECT_NAME' (empty external-volumes.txt)."
            exit 0
        fi

        if [[ "${2:-}" != "--yes" && "${2:-}" != "-y" ]]; then
            echo "This removes shared caches for project '$DEV_PROJECT_NAME', used by ALL its worktrees:"
            printf '  %s\n' "${_caches[@]}"
            read -rp "Continue? [y/N] " answer
            if [[ "$answer" != [yY]* ]]; then
                exit 0
            fi
        fi

        _rc=0
        for _v in "${_caches[@]}"; do
            if ! docker volume inspect "$_v" >/dev/null 2>&1; then
                echo "absent, skipped: $_v"
                continue
            fi
            _users="$(docker ps -a --filter volume="$_v" --format '{{.Names}}' | paste -sd, -)"
            if [ -n "$_users" ]; then
                echo "in use, not removed: $_v (containers: $_users)" >&2
                _rc=1
                continue
            fi
            if docker volume rm "$_v" >/dev/null 2>&1; then
                echo "removed: $_v"
            else
                echo "failed: $_v" >&2
                _rc=1
            fi
        done
        if [ "$_rc" -ne 0 ]; then
            echo "Some caches were not removed. Stop the containers listed above first ('devcontainer down' in each worktree), then retry." >&2
        fi
        exit "$_rc"
        ;;
    exec)
        shift
        if [ $# -eq 0 ]; then
            require_tty exec
            set -- bash
        fi
        ensure_up
        dc_exec "$@"
        ;;
    claude)
        shift
        require_tty claude
        ensure_up
        danger_args=()
        if [ -n "${DEV_DANGEROUSLY_SKIP_PERMISSIONS:-}" ]; then
            danger_args=(--dangerously-skip-permissions)
            echo "Entering claude in $DEV_CONTAINER_NAME (--dangerously-skip-permissions)..."
        else
            echo "Entering claude in $DEV_CONTAINER_NAME..."
        fi
        model_args=()
        [ -n "${DEV_MODEL_VERSION:-}" ] && model_args=(--model "$DEV_MODEL_VERSION")
        dc_exec claude "${danger_args[@]}" "${model_args[@]}" "$@"
        ;;
    claude-dangerously-skip-permissions)
        shift
        require_tty claude-dangerously-skip-permissions
        ensure_up
        echo "Entering claude in $DEV_CONTAINER_NAME (--dangerously-skip-permissions)..."
        model_args=()
        [ -n "${DEV_MODEL_VERSION:-}" ] && model_args=(--model "$DEV_MODEL_VERSION")
        dc_exec claude --dangerously-skip-permissions "${model_args[@]}" "$@"
        ;;
    refresh-ssh)
        if ! is_running; then
            echo "error: container is not running" >&2
            exit 1
        fi
        setup_ssh_forward
        echo "SSH agent forwarded into $DEV_CONTAINER_NAME"
        ;;
    refresh-gpg)
        if ! is_running; then
            echo "error: container is not running" >&2
            exit 1
        fi
        setup_gpg_forward
        echo "GPG agent forwarded into $DEV_CONTAINER_NAME"
        ;;
    refresh-x11)
        if ! is_running; then
            echo "error: container is not running" >&2
            exit 1
        fi
        setup_x11_forward
        echo "X11 forwarded into $DEV_CONTAINER_NAME (DISPLAY=${DISPLAY:-unset})"
        ;;
    copy-host-transcripts)
        if ! is_running; then
            echo "error: container is not running (start with 'devcontainer up' first)" >&2
            exit 1
        fi
        copy_host_transcripts
        ;;
    fix-credentials)
        if ! is_running; then
            echo "error: container is not running (start with 'devcontainer up' first)" >&2
            exit 1
        fi
        dc exec -u root app sh -c '
            rm -f /home/vscode/.claude/.credentials.json
            ln -s credentials/.credentials.json /home/vscode/.claude/.credentials.json
            chown -h vscode:vscode /home/vscode/.claude/.credentials.json
        '
        echo "Credentials symlink repaired in $DEV_CONTAINER_NAME"
        ;;
    fix-network)
        container_id="$(dc ps -aq app 2>/dev/null | head -1)" || true
        if [ -z "$container_id" ]; then
            echo "error: no container found for $DEV_CONTAINER_NAME" >&2
            exit 1
        fi
        disconnect_stale_networks "$container_id" && fixed=0 || fixed=$?
        if [ "$fixed" -eq 0 ]; then
            echo "No stale networks found on $DEV_CONTAINER_NAME"
        else
            echo "Removed $fixed stale network(s). Run 'devcontainer up' to restart."
        fi
        ;;
    ps)
        shift
        count=0
        if [ "${1:-}" = "--all" ]; then
            for cid in $(docker ps -q); do
                name="$(docker inspect --format '{{.Name}}' "$cid" | sed 's|^/||')"
                n="$(docker exec "$cid" pgrep -cx claude 2>/dev/null)" || continue
                [ "$n" -gt 0 ] || continue
                ((++count))
                printf "  %s: %d session%s\n" "$name" "$n" "$([ "$n" -ne 1 ] && echo s)"
            done
        else
            for cid in $(docker ps -q --filter "name=^${DEV_PROJECT_NAME}-dev-"); do
                name="$(docker inspect --format '{{.Name}}' "$cid" | sed 's|^/||')"
                n="$(docker exec "$cid" pgrep -cx claude 2>/dev/null)" || n=0
                ((++count))
                printf "  %s: %d session%s\n" "$name" "$n" "$([ "$n" -ne 1 ] && echo s)"
            done
        fi
        printf "%d container%s running\n" "$count" "$([ "$count" -ne 1 ] && echo s)"
        ;;
    audit)
        shift
        audit_log="$DEV_WORKSPACE/.claude/container-audit/audit.jsonl"
        if [ "${1:-}" = "--clear" ]; then
            rm -f "$audit_log"
            echo "Audit log cleared."
            exit 0
        fi
        if [ ! -f "$audit_log" ]; then
            echo "No audit log found at $audit_log"
            exit 0
        fi
        python3 "$DEV_BASE_DIR/audit-report.py" "$audit_log" "${1:---summary}" \
            "$DEV_PROJECT_DIR/audit-prefixes.txt"
        ;;
    unlock)
        if [ ! -f "$DEV_LOCKFILE" ]; then
            echo "No lockfile found ($DEV_LOCKFILE)"
            exit 0
        fi
        # Test whether any process still holds the flock
        if flock -n "$DEV_LOCKFILE" true 2>/dev/null; then
            rm -f "$DEV_LOCKFILE"
            echo "Removed stale lockfile: $DEV_LOCKFILE"
        else
            pids="$(fuser "$DEV_LOCKFILE" 2>/dev/null | tr -s ' ')" || true
            if [ -z "$pids" ]; then
                echo "Lock is actively held by unknown PID" >&2
                exit 1
            fi
            echo "Lock is actively held:" >&2
            for pid in $pids; do
                cmd="$(ps -p "$pid" -o cmd= 2>/dev/null)" || cmd="(exited)"
                printf "  PID %-8s %s\n" "$pid" "$cmd" >&2
            done
            echo ""
            read -rp "Kill these processes and remove lockfile? [y/N] " answer
            if [[ "$answer" != [yY]* ]]; then
                exit 1
            fi
            for pid in $pids; do
                kill "$pid" 2>/dev/null && echo "Killed PID $pid" || echo "PID $pid already exited"
            done
            rm -f "$DEV_LOCKFILE"
            echo "Removed lockfile: $DEV_LOCKFILE"
        fi
        ;;
    status)
        if is_running; then
            echo "running: $DEV_CONTAINER_NAME (workspace: $DEV_WORKSPACE)"
        else
            echo "stopped"
        fi
        echo "overlay: $_overlay_label"
        ;;
    resolve)
        echo "Resolved configuration for workspace: $DEV_WORKSPACE"
        echo ""
        echo "Overlay resolution:"
        _matched=false
        if [ -d "$DEV_MAIN_TREE/.devcontainer" ]; then
            echo "  [matched] .devcontainer/ (workspace-local override)"
            _matched=true
        else
            echo "  [skipped] .devcontainer/ — not present"
        fi
        _tier2="$DEV_BASE_DIR/projects/$DEV_PROJECT_NAME"
        if $_matched; then
            [ -d "$_tier2" ] && echo "  [skipped] projects/$DEV_PROJECT_NAME/ — superseded"
        elif [ -d "$_tier2" ]; then
            echo "  [matched] projects/$DEV_PROJECT_NAME/"
            _matched=true
        else
            echo "  [skipped] projects/$DEV_PROJECT_NAME/ — not present"
        fi
        if $_matched; then
            echo "  [skipped] defaults/ — superseded"
        else
            echo "  [fallback] defaults/"
        fi
        echo ""
        echo "  overlay:  $_overlay_label"
        echo "  from:     $DEV_PROJECT_DIR"
        echo ""
        echo "Resolved values:"
        echo "  PROJECT_NAME=$DEV_PROJECT_NAME"
        echo "  MODEL_VERSION=${DEV_MODEL_VERSION:-<unset>}"
        echo "  DANGEROUSLY_SKIP_PERMISSIONS=${DEV_DANGEROUSLY_SKIP_PERMISSIONS:-<unset>}"
        echo "  CONTAINER_NAME=$DEV_CONTAINER_NAME"
        if [ -f "$_project_env" ]; then
            echo ""
            echo "Sources:"
            echo "  project.env: $_project_env"
        fi
        ;;
    list)
        _wt_paths=()
        _wt_branches=()
        _wt_path="" _wt_branch=""
        _flush_wt() {
            if [[ -n "$_wt_path" ]]; then
                _wt_paths+=("$_wt_path")
                _wt_branches+=("${_wt_branch:-(detached)}")
            fi
            _wt_path="" _wt_branch=""
        }
        while IFS= read -r line; do
            case "$line" in
                worktree\ *) _flush_wt; _wt_path="${line#worktree }" ;;
                branch\ *)   _wt_branch="${line#branch refs/heads/}" ;;
            esac
        done < <(git worktree list --porcelain)
        _flush_wt
        printf '%-24s %-12s %s\n' "WORKTREE" "STATUS" "OVERLAY"
        for i in "${!_wt_paths[@]}"; do
            _wt="${_wt_paths[$i]}"
            _br="${_wt_branches[$i]}"
            _resolved="$_wt/.envrcs/.resolved-env"
            _cname=""
            if [ -f "$_resolved" ]; then
                # shellcheck disable=SC1090
                _cname="$(. "$_resolved" && printf '%s' "$CONTAINER_NAME")" 2>/dev/null || true
            fi
            [ -z "$_cname" ] && _cname="${DEV_PROJECT_NAME}-dev-$(basename "$_wt")"
            if ! docker inspect --format '{{.State.Running}}' "$_cname-app-1" >/dev/null 2>&1; then
                _st="not created"
            elif docker inspect --format '{{.State.Running}}' "$_cname-app-1" 2>/dev/null | grep -q true; then
                _st="running"
            else
                _st="stopped"
            fi
            _ov="$(project_dir_label "$(resolve_project_dir "$DEV_BASE_DIR" "$_wt" "$DEV_PROJECT_NAME")" "$DEV_BASE_DIR")"
            printf '%-24s %-12s %s\n' "$_br" "$_st" "$_ov"
        done
        ;;
    logs)
        shift
        dc logs "$@"
        ;;
    *)
        show_usage >&2
        exit 1
        ;;
esac
