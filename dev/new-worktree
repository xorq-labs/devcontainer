#!/usr/bin/env bash
set -euo pipefail

branch="${1:?usage: new-worktree <branch-name>}"
_base="$(cd "$(dirname "$(readlink -f "$0")")/.." && pwd)"
. "$_base/lib/git.sh"
main_tree="$(dev_main_tree)"

_project_name="$(basename "$main_tree")"
_project_dir="$(resolve_project_dir "$_base" "$main_tree" "$_project_name")"
echo "worktree overlay: $(project_dir_label "$_project_dir" "$_base")" >&2
dest="$(dirname "$main_tree")/${_project_name}-${branch//\//-}"

install_hooks
git worktree add "$dest" "$branch" >&2
git worktree lock "$dest" \
    --reason "locked by new-worktree to prevent container-side prune" \
    2>/dev/null || true
cd "$dest"
"$_base/dev/setup-worktree" >&2
direnv allow >&2 2>/dev/null || true

echo "$dest"
