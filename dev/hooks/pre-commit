#!/usr/bin/env bash
# Custom pre-commit hook that works on both the host and inside the container.
# The generated hook from `pre-commit install` bakes in an absolute Python path
# that only exists in the environment where it was installed. This hook finds
# pre-commit via .tools/bin (host, set up by .envrc.user.uv) or PATH (container).

set -euo pipefail

ROOT="$(git rev-parse --show-toplevel)"

if [ -x "$ROOT/.tools/bin/pre-commit" ]; then
    exec "$ROOT/.tools/bin/pre-commit" hook-impl \
        --config=.pre-commit-config.yaml --hook-type=pre-commit -- "$@"
elif command -v pre-commit > /dev/null; then
    exec pre-commit hook-impl \
        --config=.pre-commit-config.yaml --hook-type=pre-commit -- "$@"
else
    echo 'pre-commit not found. Install with: uv tool install pre-commit' >&2
    exit 1
fi
