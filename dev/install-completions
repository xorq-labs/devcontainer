#!/usr/bin/env bash
set -euo pipefail

# Install devcontainer shell completions to the canonical per-shell location.
#
# Usage:
#   devcontainer install-completions              # install for every shell with a binary present
#   devcontainer install-completions bash         # install for a specific shell
#   devcontainer install-completions bash zsh      # install for several
#   devcontainer install-completions --print-paths # show the target paths and exit
#
# Completion content is generated by `devcontainer-completions <shell>` (the
# single source of truth); this script only writes it to the location each
# shell autoloads from. XDG base-dir vars are honored so it respects a
# customized environment.

_dir="$(cd "$(dirname "$(readlink -f "$0")")" && pwd)"
_gen="$_dir/devcontainer-completions"

[ -x "$_gen" ] || { echo "error: generator not found or not executable: $_gen" >&2; exit 1; }

# Canonical autoload path for each shell:
#   bash — bash-completion's per-user completions dir (loaded on demand by
#          the bash-completion package)
#   zsh  — a site-functions dir; must be on $fpath (hint printed below)
#   fish — fish loads every *.fish in its completions dir automatically
target_path() {
    case "$1" in
        bash) printf '%s/bash-completion/completions/devcontainer\n' "${XDG_DATA_HOME:-$HOME/.local/share}" ;;
        zsh)  printf '%s/zsh/site-functions/_devcontainer\n' "${XDG_DATA_HOME:-$HOME/.local/share}" ;;
        fish) printf '%s/fish/completions/devcontainer.fish\n' "${XDG_CONFIG_HOME:-$HOME/.config}" ;;
        *)    return 1 ;;
    esac
}

post_install_hint() {
    case "$1" in
        bash) echo "  start a new shell (requires the bash-completion package)" ;;
        zsh)  echo "  ensure '$(dirname "$2")' is on your \$fpath before compinit, e.g. add to ~/.zshrc:" \
                   && echo "    fpath=($(dirname "$2") \$fpath)" ;;
        fish) echo "  loaded automatically in new fish shells" ;;
    esac
}

install_one() {
    local shell="$1" dest
    dest="$(target_path "$shell")" || { echo "error: unsupported shell: $shell" >&2; return 1; }
    mkdir -p "$(dirname "$dest")"
    "$_gen" "$shell" > "$dest"
    echo "installed $shell completions → $dest"
    post_install_hint "$shell" "$dest"
}

print_paths=false
shells=()
for arg in "$@"; do
    case "$arg" in
        --print-paths) print_paths=true ;;
        -*) echo "error: unknown flag: $arg" >&2; exit 1 ;;
        bash|zsh|fish) shells+=("$arg") ;;
        *) echo "error: unsupported shell: $arg (try bash, zsh, or fish)" >&2; exit 1 ;;
    esac
done

# Default: every supported shell whose binary is installed.
if [ "${#shells[@]}" -eq 0 ]; then
    for s in bash zsh fish; do
        command -v "$s" >/dev/null 2>&1 && shells+=("$s")
    done
    if [ "${#shells[@]}" -eq 0 ]; then
        echo "error: no supported shell (bash/zsh/fish) found on PATH; pass one explicitly" >&2
        exit 1
    fi
fi

if $print_paths; then
    for s in "${shells[@]}"; do
        printf '%-5s %s\n' "$s" "$(target_path "$s")"
    done
    exit 0
fi

for s in "${shells[@]}"; do
    install_one "$s"
done
