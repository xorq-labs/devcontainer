{
  "name": "batchcorder",
  // Tripwire: blocks VS Code "Reopen in Container" (unsupported).
  // Start the container via `dev/devcontainer up`, then attach VS Code.
  "initializeCommand": "printf 'ERROR: use dev/devcontainer to start this container.\\nSee the devcontainer repo README.\\n' >&2; exit 1",
  "dockerComposeFile": "docker-compose.yml",
  "service": "app",
  "workspaceFolder": "/workspaces/src",
  "remoteUser": "vscode",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "charliermarsh.ruff",
        "tamasfe.even-better-toml",
        "rust-lang.rust-analyzer",
        "eamodio.gitlens"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/workspaces/src/.venv/bin/python"
      }
    }
  }
}
